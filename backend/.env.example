# Django
DJANGO_SECRET_KEY=dev-secret-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (matches docker-compose.yml)
DATABASE_URL=postgres://codebaseqa:codebaseqa@localhost:5432/codebaseqa

# --- LLM provider (who answers questions) ---
# "groq" = free, no credit card (default). "anthropic" = Claude (paid).
LLM_PROVIDER=groq

# Groq — get a free key at https://console.groq.com (no card required)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (Claude) — only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# --- Embeddings ---
# "local" = on-device via fastembed (no key, no card; default).
# "voyage" = Voyage AI (code-specialized, but requires a Voyage key + a card).
EMBED_PROVIDER=local
LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5
# Dimension MUST match the model: 384 for bge-small-en-v1.5, 1024 for voyage-code-3.
EMBED_DIM=384
# Only used if EMBED_PROVIDER=voyage:
VOYAGE_API_KEY=pa-...
VOYAGE_EMBED_MODEL=voyage-code-3

# --- Cost / usage guardrails ---
# Max output tokens per answer, and how thorough Claude is (low|medium|high|max)
MAX_OUTPUT_TOKENS=1536
ANTHROPIC_EFFORT=medium
# Retrieval size (bounds input tokens)
RETRIEVAL_TOP_K=6
MAX_CONTEXT_CHARS_PER_CHUNK=2400
# Embeddings cap per repo (bounds Voyage cost on huge repos)
MAX_CHUNKS_PER_REPO=6000
# Daily app-level budget (resets 00:00 UTC). Refuses requests past EITHER limit.
DAILY_TOKEN_BUDGET=2000000
DAILY_COST_BUDGET_USD=2.00
# Claude pricing per 1M tokens (claude-opus-4-8 defaults) for the cost estimate
MODEL_INPUT_COST_PER_MTOK=5.0
MODEL_OUTPUT_COST_PER_MTOK=25.0

# --- Per-IP rate limits ---
THROTTLE_ASK_BURST=15/min
THROTTLE_ASK_DAY=200/day
THROTTLE_INDEX_BURST=10/hour

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173
